# Private key for deployment (must have 0G tokens on target network)
PRIVATE_KEY=your_wallet_private_key_here

# RPC URL (defaults to testnet if unset)
# Testnet: https://evmrpc-testnet.0g.ai
# Mainnet: https://evmrpc.0g.ai
OG_RPC_URL=https://evmrpc-testnet.0g.ai

# Safety guard for mainnet deployment
# Set to 'yes' ONLY after reading docs/MAINNET-CHECKLIST.md
I_HAVE_READ_MAINNET_CHECKLIST=no
