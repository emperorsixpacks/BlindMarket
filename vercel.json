{
    "experimentalServices": {
        "frontend": {
            "entrypoint": "frontend",
            "routePrefix": "/",
            "framework": "vite"
        },
        "backend": {
            "entrypoint": "backend",
            "routePrefix": "/_/backend"
        }
    },
    "rewrites": [
        { "source": "/((?!_/|api/|health|assets/|.*\\.).*)", "destination": "/index.html" }
    ]
}
